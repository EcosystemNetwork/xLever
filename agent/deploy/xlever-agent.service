[Unit]
Description=xLever AI Trading Agent
Documentation=https://github.com/madschristensen99/xLever
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=xlever
Group=xlever
WorkingDirectory=/opt/xlever/agent
Environment=PATH=/opt/xlever/venv/bin:/usr/local/bin:/usr/bin
EnvironmentFile=/opt/xlever/agent/.env

# Main agent process
ExecStart=/opt/xlever/venv/bin/xlever-agent
ExecReload=/bin/kill -HUP $MAINPID

# Restart policy
Restart=always
RestartSec=10
StartLimitInterval=300
StartLimitBurst=5

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/opt/xlever/agent
ReadWritePaths=/var/log/xlever

# Resource limits
MemoryMax=2G
CPUQuota=80%

# Logging
StandardOutput=append:/var/log/xlever/agent.log
StandardError=append:/var/log/xlever/agent-error.log

[Install]
WantedBy=multi-user.target
