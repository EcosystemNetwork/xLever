# Blockchain Configuration
RPC_URL=https://rpc-gel-sepolia.inkonchain.com/
CHAIN_ID=763373
PRIVATE_KEY=your_private_key_here

# API Keys
TAVILY_API_KEY=your_tavily_api_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./agent.db

# Agent Settings
AGENT_MODE=simulation  # simulation or live
LOOP_INTERVAL=300  # seconds between decision cycles

# Risk Management Limits
MAX_LEVERAGE_BPS=50000  # 5x leverage (basis points)
MAX_POSITION_USDC=1000  # Maximum position size in USDC
STOP_LOSS_PCT=10  # Stop loss percentage
TAKE_PROFIT_PCT=20  # Take profit percentage

# Logging
LOG_LEVEL=INFO
