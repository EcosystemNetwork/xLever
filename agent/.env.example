# ═══════════════════════════════════════════════════════════════════
# xLever AI Trading Agent - Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ─── Blockchain Configuration ─────────────────────────────────────
# Ink Sepolia Testnet (default)
RPC_URL=https://rpc-gel-sepolia.inkonchain.com/
CHAIN_ID=763373

# Your wallet private key (WITHOUT 0x prefix)
# WARNING: Use a dedicated trading wallet, not your main wallet!
PRIVATE_KEY=your_private_key_here

# ─── API Keys ─────────────────────────────────────────────────────
# Tavily AI Search API for market intelligence
# Get your key at: https://tavily.com/
TAVILY_API_KEY=tvly-your_api_key_here

# ─── Database ─────────────────────────────────────────────────────
# SQLite (default, good for development)
DATABASE_URL=sqlite+aiosqlite:///./xlever_agent.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/xlever_agent

# ─── Agent Mode ───────────────────────────────────────────────────
# simulation = Paper trading (no real transactions)
# live = Real on-chain execution (USE WITH CAUTION!)
AGENT_MODE=simulation

# Seconds between decision cycles (default: 5 minutes)
LOOP_INTERVAL=300

# ─── Human-in-the-Loop (HITL) Settings ────────────────────────────
# autonomous = Agent trades without approval
# approval_required = All trades need human approval
# approval_above_threshold = Trades above threshold need approval
# notifications_only = Agent notifies but doesn't trade
HITL_MODE=approval_required

# Threshold in USDC for approval_above_threshold mode
HITL_THRESHOLD_USDC=500

# Timeout for pending approvals (seconds, default: 5 minutes)
HITL_TIMEOUT=300

# ─── Risk Management Limits ───────────────────────────────────────
# Maximum leverage in basis points (40000 = 4x)
MAX_LEVERAGE_BPS=40000

# Maximum position size in USDC
MAX_POSITION_USDC=1000

# Stop loss percentage (triggers automatic close)
STOP_LOSS_PCT=10

# Take profit percentage (triggers automatic close)
TAKE_PROFIT_PCT=25

# Daily loss limit percentage (pauses trading if exceeded)
DAILY_LOSS_LIMIT_PCT=5

# ─── API Server Settings ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080

# CORS origins (comma-separated, use * for development only)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── WebSocket Settings ───────────────────────────────────────────
WS_HOST=localhost
WS_PORT=8765

# ─── Logging ──────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional, logs to console if not set)
# LOG_FILE=/var/log/xlever-agent/agent.log

# ─── Deployed Contract Addresses (Ink Sepolia) ────────────────────
# These are pre-configured for Ink Sepolia testnet
# Only change if deploying to a different network

# Euler Vault Controller
EVC_ADDRESS=0x9B8d1851bCc06ac265c1c1ACaBD0F71E69DD312c

# Hedging Vaults
WSPY_VAULT_ADDRESS=0xd0673BeB607CA2136b126d34ED0D3Ff7826c93EE
WQQQ_VAULT_ADDRESS=0x3Bc3c0D268455aD7eAe1432f57f3C24f42EdC7C8

# Tokens
USDC_ADDRESS=0xFabab97dCE620294D2B0b0e46C68964e326300Ac
WSPY_ADDRESS=0x9eF9f9B22d3CA9769e28e769e2AAA3C2B0072D0e
WQQQ_ADDRESS=0x267ED9BC43B16D832cB9Aaf0e3445f0cC9f536d9
