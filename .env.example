# Deployment Configuration for Ink Sepolia

# Private key for deployment (DO NOT COMMIT REAL KEY)
PRIVATE_KEY=your_private_key_here

# Network RPC URL
RPC_URL=https://rpc-gel-sepolia.inkonchain.com

# Chain ID for Ink Sepolia
CHAIN_ID=763373

# Etherscan API Key (for verification, if available)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# === Core Protocol Addresses ===

# Ethereum Vault Connector (EVC) - Required
# This needs to be deployed first or use existing deployment
# Deployed on Ink Sepolia: 0x9B8d1851bCc06ac265c1c1ACaBD0F71E69DD312c
EVC_ADDRESS=0x9B8d1851bCc06ac265c1c1ACaBD0F71E69DD312c

# Optional: Balance Tracker
BALANCE_TRACKER_ADDRESS=

# Optional: Permit2
PERMIT2_ADDRESS=

# === Deployed Contract Addresses (filled after deployment) ===

# Protocol Config
PROTOCOL_CONFIG_ADDRESS=

# Sequence Registry
SEQUENCE_REGISTRY_ADDRESS=

# EVault Implementation
EVAULT_IMPLEMENTATION_ADDRESS=

# EVault Factory
EVAULT_FACTORY_ADDRESS=

# Interest Rate Model
IRM_ADDRESS=

# === Asset Addresses ===

# USDC or base collateral asset
USDC_ADDRESS=

# xQQQ tokenized asset (for xLever protocol)
XQQQ_ADDRESS=

# === Oracle Addresses ===

# Pyth Oracle for price feeds
PYTH_ORACLE_ADDRESS=

# Price oracle adapter (if needed)
ORACLE_ADDRESS=

# === Vault Configuration ===

# Asset for vault creation
ASSET_ADDRESS=

# === xLever Protocol Specific ===

# Senior vault (for leverage traders)
SENIOR_VAULT_ADDRESS=

# Junior vault (for LPs)
JUNIOR_VAULT_ADDRESS=
