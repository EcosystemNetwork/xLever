# Deployment Configuration for Ink Sepolia

# Reown (WalletConnect) Project ID — get one at https://cloud.reown.com
VITE_REOWN_PROJECT_ID=your_project_id_here

# Private key for deployment (DO NOT COMMIT REAL KEY)
PRIVATE_KEY=your_private_key_here

# Network RPC URL
RPC_URL=https://rpc-gel-sepolia.inkonchain.com

# Chain ID for Ink Sepolia
CHAIN_ID=763373

# Etherscan API Key (for verification, if available)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# === Core Protocol Addresses ===

# Ethereum Vault Connector (EVC) - Required
# This needs to be deployed first or use existing deployment
# Deployed on Ink Sepolia: 0x9B8d1851bCc06ac265c1c1ACaBD0F71E69DD312c
EVC_ADDRESS=0x9B8d1851bCc06ac265c1c1ACaBD0F71E69DD312c

# Optional: Balance Tracker
BALANCE_TRACKER_ADDRESS=

# Optional: Permit2
PERMIT2_ADDRESS=

# === Deployed Contract Addresses (filled after deployment) ===

# Protocol Config
PROTOCOL_CONFIG_ADDRESS=

# Sequence Registry
SEQUENCE_REGISTRY_ADDRESS=

# EVault Implementation
EVAULT_IMPLEMENTATION_ADDRESS=

# EVault Factory
EVAULT_FACTORY_ADDRESS=

# Interest Rate Model
IRM_ADDRESS=

# === Asset Addresses ===

# USDC or base collateral asset
USDC_ADDRESS=

# xQQQ tokenized asset (for xLever protocol)
XQQQ_ADDRESS=

# === Oracle Addresses ===

# Pyth Network contract on Ink Sepolia (DO NOT CHANGE)
PYTH_CONTRACT_ADDRESS=0x2880aB155794e7179c9eE2e38200202908C17B43

# PythOracleAdapter — deployed adapter wrapping Pyth (filled after deployment)
PYTH_ADAPTER_ADDRESS=

# Pyth Feed IDs (hex, no 0x prefix) — see https://pyth.network/developers/price-feed-ids
PYTH_FEED_QQQ_USD=9695e2b96ea7b3859da9ed25b7a46a920a776e2fdae19a7bcfdf2b219230452d
PYTH_FEED_SPY_USD=19e09bb805456ada3979a7d1cbb4b6d63babc3a0f8e8a9509f68afa5c4c11cd5
PYTH_FEED_AAPL_USD=49f6b65cb1de6b10eaf75e7c03ca029c306d0357e91b5311b175084a5ad55688
PYTH_FEED_NVDA_USD=b1073854ed24cbc755dc527418f52b7d271f6cc967bbf8d8129112b18860a593
PYTH_FEED_TSLA_USD=16dad506d7db8da01c87581c87ca897a012a153557d4d578c3b9c9e1bc0632f1

# Legacy TWAP Oracle (internal, deployed by vault constructor)
ORACLE_ADDRESS=

# === Vault Configuration ===

# Asset for vault creation
ASSET_ADDRESS=

# === xLever Protocol Specific ===

# Senior vault (for leverage traders)
SENIOR_VAULT_ADDRESS=

# Junior vault (for LPs)
JUNIOR_VAULT_ADDRESS=

# === Backend API ===

# PostgreSQL connection
DATABASE_URL=postgresql+asyncpg://xlever:xlever@localhost:5432/xlever

# Redis cache
REDIS_URL=redis://localhost:6379/0

# API server
DEBUG=false
CORS_ORIGINS=["http://localhost:8080","http://localhost:5173","http://localhost:3000"]
YAHOO_CACHE_TTL=300
